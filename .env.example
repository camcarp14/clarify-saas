# ---------- Frontend (Vite) ----------
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ---------- Netlify functions ----------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server only, never VITE_

APP_URL=https://app.clarifypaidsearch.com

# Google Ads API
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_DEVELOPER_TOKEN=...
GOOGLE_LOGIN_CUSTOMER_ID=1234567890        # your Clarify MCC, digits only
GOOGLE_ADS_API_VERSION=v18                 # bump when Google sunsets versions

# Secrets (generate: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=64_hex_chars_here
STATE_SIGNING_SECRET=another_random_string
INTERNAL_SYNC_SECRET=another_random_string     # shared by both the Ads sync AND the outreach engine

# Stripe — one bundled subscription now covers both modules; same 3 price ids as before
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...

# Email (Resend) — used for Ads alert emails
RESEND_API_KEY=re_...
ALERT_FROM_EMAIL=alerts@clarifypaidsearch.com

# ---------- Outreach module ----------
# Gmail OAuth (same Google Cloud project as Ads works fine, or a separate one — either way,
# enable the Gmail API and add these scopes to the consent screen: gmail.send, gmail.readonly)
GOOGLE_PLACES_API_KEY=AIza...             # enable Places API (New) in the same Cloud project

# Microsoft OAuth (Entra app registration: Mail.Send, Mail.Read, User.Read, offline_access)
MS_CLIENT_ID=...
MS_CLIENT_SECRET=...

# AI drafting for outreach copy (metered by plan tier, not exposed to the audit/numbers path)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# SMS (Pro tier) — customers connect their own Twilio account in Settings; nothing global needed here.
